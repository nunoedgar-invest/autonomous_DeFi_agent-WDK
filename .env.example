# =========================================
# 🔐 WALLET CONFIGURATION
# =========================================

# Private key of the agent wallet
# NEVER commit your real private key
PRIVATE_KEY=your_private_key_here


# =========================================
# 🌐 BLOCKCHAIN CONFIGURATION
# =========================================

# RPC endpoint (Ethereum / EVM compatible)
RPC_URL=https://rpc.ankr.com/eth

# Optional: Chain ID (default = 1 for Ethereum mainnet)
CHAIN_ID=1


# =========================================
# ⛽ GAS CONFIGURATION
# =========================================

# Maximum acceptable gas price (in GWEI)
MAX_GAS_PRICE_GWEI=100

# Gas safety multiplier (e.g. 1.2 = +20%)
GAS_BUFFER=1.2


# =========================================
# ⚖️ RISK MANAGEMENT CONFIG
# =========================================

# Maximum trade size (USD equivalent)
MAX_TRADE_SIZE_USD=1000

# Maximum daily loss allowed
MAX_DAILY_LOSS_USD=500

# Minimum ETH balance required for operation
MIN_WALLET_BALANCE_ETH=0.05


# =========================================
# 🤖 AGENT LOOP CONFIG
# =========================================

# Time between execution cycles (seconds)
LOOP_INTERVAL=10

# Optional: max cycles for demo mode
MAX_CYCLES=5


# =========================================
# 🌍 API CONFIG (OPTIONAL)
# =========================================

# Backend API URL (for frontend)
API_BASE_URL=http://localhost:3001/api


